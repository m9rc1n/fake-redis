{
  "name": "fake-redis-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "In-memory Redis fake for testing with ioredis and node-redis",
  "license": "MIT",
  "author": "Marcin Urbanski",
  "homepage": "https://github.com/marcinnurbanski/fake-redis#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcinnurbanski/fake-redis.git"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r run test:unit",
    "test:integration": "pnpm -r run test:integration",
    "test:e2e": "pnpm -r run test:e2e",
    "test:conformance": "pnpm --filter @fake-redis/shared-tests test",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.27.11",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
